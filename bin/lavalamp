#!/usr/bin/env bash
set -euo pipefail

# lavalamp — AI coding harness

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
REPO_DIR="${SCRIPT_DIR}/.."
SERVER_PATH="${REPO_DIR}/dist/server.mjs"

show_help() {
  cat <<'EOF'
lavalamp — AI coding harness

USAGE:
  lavalamp                       Start interactive session in current directory
  lavalamp -p "PROMPT"           Run a single prompt and exit
  lavalamp --continue            Resume a previous session
  lavalamp --workspace /path     Set workspace directory (default: cwd)
  lavalamp --model MODEL         Override default model
  lavalamp models                List known models
  lavalamp config show           Show persisted config
  lavalamp config set KEY VALUE  Persist model/Gateway config

PIPE MODE:
  cat file.ts | lavalamp -p "review this"     Pipe stdin as context
  echo "question" | lavalamp -p "answer this" Pipe stdin as context

OPTIONS:
  -p, --print PROMPT             Run a single prompt and exit (aliases: --inline, -i)
  -c, --continue                 Resume a previous session
  -w, --workspace PATH           Set workspace directory
  -m, --model MODEL              Override default model
      --output-format FORMAT     Output format: text (default) or json
      --quiet                    Suppress status messages in -p mode
  -h, --help                     Show this help
  -v, --version                  Show version

KEYBINDINGS:
  Enter       submit prompt / steer (during processing)
  Tab         queue follow-up (during processing) / trigger autocomplete
  Up/Down     browse command history
  Shift+Tab   toggle plan mode
  Ctrl+C      interrupt / exit (double-press)
  Ctrl+D      exit (empty input)

EXAMPLES:
  lavalamp
  lavalamp --continue
  lavalamp -p "read greet.ts and change the greeting to use Hi instead of Hello"
  lavalamp -p "explain this repo" --output-format json
  cat error.log | lavalamp -p "what caused this crash?"
  git diff | lavalamp -p "review these changes"
  lavalamp -m anthropic/claude-sonnet-4-20250514 -p "refactor auth module"

ENVIRONMENT:
  LAVALAMP_MODEL          Override default model (e.g. "anthropic/claude-sonnet-4-20250514")
  LAVALAMP_WORKSPACE      Override workspace directory
  ANTHROPIC_API_KEY       API key for Anthropic models (BYOK)
  OPENAI_API_KEY          API key for OpenAI models (BYOK)
  OPENROUTER_API_KEY      API key for OpenRouter models (BYOK)
EOF
}

show_version() {
  echo "lavalamp 0.1.0"
}

# Handle subcommands before flag parsing
case "${1:-}" in
  login|logout|status)
    exec bun run "${REPO_DIR}/src/cli/auth.ts" "$@"
    ;;
  config|models)
    exec bun run "${REPO_DIR}/src/cli/config.ts" "$@"
    ;;
esac

# Parse args
PRINT_MODE=false
PRINT_PROMPT=""
WORKSPACE=""
MODEL=""
RESUME_SESSION=false
OUTPUT_FORMAT="text"
QUIET=false

while [[ $# -gt 0 ]]; do
  case "$1" in
    -p|--print|--inline|-i)
      PRINT_MODE=true
      shift
      if [[ $# -gt 0 ]]; then
        PRINT_PROMPT="$1"
        shift
      else
        echo "[lavalamp] Error: -p requires a prompt argument" >&2
        exit 1
      fi
      ;;
    -c|--continue)
      RESUME_SESSION=true
      shift
      if [[ $# -gt 0 && ! "$1" =~ ^- ]]; then
        SESSION_ID="$1"
        shift
      fi
      ;;
    -w|--workspace)
      shift
      if [[ $# -gt 0 ]]; then
        WORKSPACE="$(cd "$1" 2>/dev/null && pwd || echo "$1")"
        shift
      else
        echo "[lavalamp] Error: --workspace requires a path" >&2
        exit 1
      fi
      ;;
    -m|--model)
      shift
      if [[ $# -gt 0 ]]; then
        MODEL="$1"
        shift
      else
        echo "[lavalamp] Error: --model requires a model ID" >&2
        exit 1
      fi
      ;;
    --output-format|--format)
      shift
      if [[ $# -gt 0 ]]; then
        OUTPUT_FORMAT="$1"
        shift
      else
        echo "[lavalamp] Error: --output-format requires text or json" >&2
        exit 1
      fi
      ;;
    --quiet)
      QUIET=true
      shift
      ;;
    -h|--help)
      show_help
      exit 0
      ;;
    -v|--version)
      show_version
      exit 0
      ;;
    *)
      echo "[lavalamp] Unknown argument: $1" >&2
      echo "[lavalamp] Use --help for usage information" >&2
      exit 1
      ;;
  esac
done

# Build environment
export LAVALAMP_WORKSPACE="${WORKSPACE:-$(pwd)}"
if [ -n "$MODEL" ]; then
  export LAVALAMP_MODEL="$MODEL"
fi

if [ "$PRINT_MODE" = true ]; then
  EXTRA_ARGS=(-p)
  if [ -n "$PRINT_PROMPT" ]; then
    EXTRA_ARGS+=("$PRINT_PROMPT")
  fi
  EXTRA_ARGS+=(--output-format "$OUTPUT_FORMAT")
  if [ "$QUIET" = true ]; then
    EXTRA_ARGS+=(--quiet)
  fi

  cd "$REPO_DIR" && PORT=48392 bun run src/run.ts "${EXTRA_ARGS[@]}"
else
  EXTRA_ARGS=()
  if [ "$RESUME_SESSION" = true ]; then
    EXTRA_ARGS+=(--continue)
    if [ -n "${SESSION_ID:-}" ]; then
      EXTRA_ARGS+=("$SESSION_ID")
    fi
  fi

  cd "$REPO_DIR" && PORT=48392 bun run src/run.ts "${EXTRA_ARGS[@]}"
fi
