		for (let i = 0; i < text.length; i++) {
			element.textContent += text[i];
			
			// Show and filter autocomplete box if typing a slash command
			if (text.startsWith('/') && tuiCompletionBox) {
				tuiCompletionBox.style.display = 'flex';
				const val = element.textContent;
				const clearRow = document.getElementById('ac-clear');
				const helpRow = document.getElementById('ac-help');
				const quitRow = document.getElementById('ac-quit');
				
				if (clearRow && helpRow && quitRow) {
					if (val === '/') {
						clearRow.style.display = 'flex';
						helpRow.style.display = 'flex';
						quitRow.style.display = 'flex';
						clearRow.className = 'tui-completion-row active';
						helpRow.className = 'tui-completion-row';
						quitRow.className = 'tui-completion-row';
					} else if (val.startsWith('/c')) {
						clearRow.style.display = 'flex';
						helpRow.style.display = 'none';
						quitRow.style.display = 'none';
						clearRow.className = 'tui-completion-row active';
