	function highlightCode(code: string) {
		const lines = code.split('\n');
		let html = '<div class="code-viewer-replica">';
		
		lines.forEach((line, idx) => {
			let formatted = line
				.replace(/&/g, "&amp;")
				.replace(/</g, "&lt;")
				.replace(/>/g, "&gt;");
			
			// Separate comments from code to avoid regex collisions inside comments
			let comment = '';
			const commentIdx = formatted.indexOf('//');
			if (commentIdx !== -1) {
				comment = `<span class="tok-comment">${formatted.substring(commentIdx)}</span>`;
				formatted = formatted.substring(0, commentIdx);
			}

			// Highlight string literals and template literals
			formatted = formatted.replace(/(['"`])(.*?)\1/g, '<span class="tok-string">$1$2$1</span>');

			// Highlight Types
			formatted = formatted.replace(/\b(number|string|any|Promise|LRUCache|DatabaseClient|Map|V|K|void|boolean)\b/g, '<span class="tok-type">$1</span>');

			// Highlight Functions
			formatted = formatted.replace(/\b(delete|keys|next|value|JSON|stringify|has|get|set|run|executeQuery|log)\b/g, '<span class="tok-func">$1</span>');

			// Highlight Keywords
			formatted = formatted.replace(/\b(class|constructor|export|function|const|let|for|while|return|private|new|await|async|import|from|if|else|break)\b/g, '<span class="tok-keyword">$1</span>');

			// Re-append comment if present
			formatted = formatted + comment;

			html += `
				<div class="code-viewer-line">
					<span class="code-line-num">${idx + 1}</span>
					<span class="code-line-sep">│</span>
					<span class="code-line-content">${formatted}</span>
				</div>
			`;
		});

		html += '</div>';
		return html;
	}

	function runPlayback() {
		if (currentStep >= demoScript.length) {
			if (tuiTaskStatusText) tuiTaskStatusText.textContent = 'idle';
			if (tuiTaskStatusBar) tuiTaskStatusBar.style.display = 'none';
			stopSpinner();
			stopBottomSpinner();
			
			// Wait 3 seconds, then animate entering the /clear command to loop
			simTimeout = setTimeout(() => {
				if (tuiInputField) {
					typeInputText('/clear', tuiInputField).then(() => {
						simTimeout = setTimeout(() => {
							// Append clear line to log
							const div = document.createElement('div');
