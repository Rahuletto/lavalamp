---
import Layout from '../layouts/Layout.astro';
---

<Layout>
	<!-- Master Layout Grid Container -->
	<div class="master-grid">
		
		<!-- Row 1: Header -->
		<header class="grid-cell col-12 nav-header font-mono">
			<a href="#" class="logo" aria-label="lavalamp">
				<pre class="logo-ascii">       _____
      /     \
      |_____|
      /  _  \
     /  ( )  \
    /    `    \
   /     _     \
  /     ( )     \
  \      )\     /
   \    (  )   /
    \  ,-(   /
     \/-----\/
     |       |
     /       \
    /________\--._
               .-._)
              (__
                 -`|E</pre>
			</a>
			<nav class="nav-links">
				<a href="#demo">tui-sandbox</a>
				<a href="#features">features</a>
				<a href="#architecture">ipc-flow</a>
				<a href="#toolbelt">toolbelt</a>
				<a href="#setup" class="cta-link">install</a>
			</nav>
			<a href="https://github.com/rahuletto/lavalamp" target="_blank" rel="noopener noreferrer" class="github-link">
				github
			</a>
		</header>

		<!-- Row 2: Hero Section (Full Width Column) -->
		<section class="grid-cell col-12 hero-left-cell">
			<div class="cell-padding hero-intro">
				<div class="badge font-mono">VERSION 0.1.0 // CLOUDFLARE WORKERS AI</div>
				<h1 class="hero-title">
					There are many AI assistants, <br />
					but this one is <span class="accent-italic">yours.</span>
				</h1>
				<p class="hero-desc font-serif">
					lavalamp is a minimal, local AI coding harness. Run Workers AI workloads directly on your Cloudflare account, billed directly to you. Edits files locally via precise, hash-anchored patches.
				</p>
				
				<!-- Simple CLI Installation command (curl only) -->
				<div class="install-box font-mono">
					<div class="install-command-row">
						<code class="shell-prompt" id="installCmd">curl -fsSL https://lavalamp.marban.lol/install.sh | bash</code>
						<button type="button" class="install-copy-btn" id="copyInstallBtn">Copy</button>
					</div>
				</div>
			</div>
		</section>

		<!-- Row 3: TUI Terminal Showcase (Full Width Column) -->
		<section id="demo" class="grid-cell col-12 demo-showcase-cell">
			<!-- TUI Terminal Replica -->
			<div class="tui-wrapper font-mono">
				<!-- TUI Header -->
				<div class="tui-header">
					<span class="tui-header-title">lavalamp</span>
				</div>

				<!-- TUI Scroll View -->
				<div class="tui-messages" id="tuiMessagesPanel">
					<!-- Idle ASCII logo -->
					<div class="tui-lava-lamp-container" id="tuiLavaLampBox">
						<pre class="tui-lava-lamp-art" id="tuiLavaLampArt">
       _____
      /     \
      |_____|
      /  _  \
     /  ( )  \
    /    `    \
   /     _     \
  /     ( )     \
  \      )\     /
   \    (  )   /
    \  ,-(   /
     \/-----\/
     |       |
     /       \
    /________\--._
               .-._)
              (__
                 -`|E
						</pre>

					</div>

					<!-- Output streams here -->
					<div class="tui-chat-stream" id="tuiChatStream"></div>
				</div>

				<!-- Stacked TUI Panels -->
				<div class="tui-panel-box" id="tuiTaskBox" style="display: none;">
					<div class="tui-panel-border">┌ tasks ────────────────────────────────────────────────────────────────────────┐</div>
					<div class="tui-panel-row" id="task-bst">  [ ] #1 create LRU cache in src/cache.ts</div>
					<div class="tui-panel-row" id="task-test">  [ ] #2 integrate with db in src/db.ts</div>
					<div class="tui-panel-border">└────────────────────────────────────────────────────────────────────────────────┘</div>
				</div>

				<!-- Task Status Spinner Bar -->
				<div class="tui-task-status-bar" id="tuiTaskStatusBar" style="display: none;">
					<span class="tui-spinner" id="tuiSpinner">⠋</span>
					<span class="tui-task-status-text" id="tuiTaskStatusText">idle</span>
				</div>

				<!-- Completion Box Autocomplete Replica -->
				<div class="tui-completion-box" id="tuiCompletionBox" style="display: none;">
					<div class="tui-completion-border">┌────────────────────────────────────────────────────────────────────────────────┐</div>
					<div class="tui-completion-row active" id="ac-clear"><span>  /clear</span><span class="ac-desc">clear session  </span></div>
					<div class="tui-completion-row" id="ac-help"><span>  /help</span><span class="ac-desc">show help  </span></div>
					<div class="tui-completion-row" id="ac-quit"><span>  /quit</span><span class="ac-desc">exit lavalamp  </span></div>
					<div class="tui-completion-border">└────────────────────────────────────────────────────────────────────────────────┘</div>
				</div>

				<!-- Input & Dividers -->
				<div class="tui-separator">────────────────────────────────────────────────────────────────────────────────</div>
				<div class="tui-input-row" id="tuiInputRow">
					<span class="tui-prompt-arrow">┃</span>
					<div class="tui-input-field" id="tuiInputField">Type a prompt...</div>
				</div>
				<div class="tui-separator">────────────────────────────────────────────────────────────────────────────────</div>

				<!-- Status Bar -->
				<div class="tui-status-bar">
					<span class="tui-status-spinner" id="tuiStatusSpinner"></span>
					<span class="tui-status-text">model: @cf/zai-org/glm-4.7-flash</span>
					<span class="tui-status-path">/Users/dev/math-lib</span>
				</div>
			</div>
		</section>

		<!-- Rows 4 & 5: Features (2x2 Grid) -->
		<section id="features" class="grid-cell col-6 feature-cell">
			<div class="cell-padding">
				<div class="feature-meta font-mono">02.1 / ARCHITECTURE</div>
				<h3 class="feature-heading font-serif">cloudflare workers ai</h3>
				<p class="feature-text font-mono">
					No subscription markups. Connects using Wrangler credentials, executing LLM inference tasks billed directly to your account.
				</p>
			</div>
		</section>
		<section class="grid-cell col-6 feature-cell">
			<div class="cell-padding">
				<div class="feature-meta font-mono">02.2 / EFFICIENCY</div>
				<h3 class="feature-heading font-serif">hashline patches</h3>
				<p class="feature-text font-mono">
					Integrated `@oh-my-pi/hashline` diff replacements. Applies target line updates matching specific hashes. Avoids full file transfers.
				</p>
			</div>
		</section>
		<section class="grid-cell col-6 feature-cell">
			<div class="cell-padding">
				<div class="feature-meta font-mono">02.3 / SECURITY</div>
				<h3 class="feature-heading font-serif">interactive permission gate</h3>
				<p class="feature-text font-mono">
					No unexpected changes. Prompts for verification on file updates or bash script execution. Automatically fails if left unattended.
				</p>
			</div>
		</section>
		<section class="grid-cell col-6 feature-cell">
			<div class="cell-padding">
				<div class="feature-meta font-mono">02.4 / FLOW</div>
				<h3 class="feature-heading font-serif">task lists</h3>
				<p class="feature-text font-mono">
					Define task lists before running edits. Status elements update inside border checklists as completions register.
				</p>
			</div>
		</section>

		<!-- Row 6: Two-Process Flow Diagram (Full Width) -->
		<section id="architecture" class="grid-cell col-12 arch-cell">
			<div class="section-header font-mono">
				<span class="sec-number">03 /</span>
				<h2 class="sec-title">dual-process architecture</h2>
			</div>

			<div class="arch-brutalist font-mono">
				<div class="arch-node-box">
					<div class="node-title">[ parent process ]</div>
					<div class="node-name font-serif">OpenTUI Core</div>
					<p class="node-details text-dim font-serif">Manages keyboard inputs, scroll widgets, Vim unified diff panels, and blocks execution until permission is granted.</p>
				</div>
				<div class="arch-pipe-box">
					<div class="pipe-line">────────────────────────────────────</div>
					<div class="pipe-text">bidirectional node ipc</div>
					<div class="pipe-line">────────────────────────────────────</div>
				</div>
				<div class="arch-node-box">
					<div class="node-title">[ child process ]</div>
					<div class="node-name font-serif">Flue Server</div>
					<p class="node-details text-dim font-serif">Resolves LLM tasks, executes files/bash scripts, tracks project memory logs, and runs semantic vector embeddings.</p>
				</div>
			</div>
		</section>

		<!-- Row 7: Toolbelt Tabs (Full Width) -->
		<section id="toolbelt" class="grid-cell col-12 toolbelt-cell">
			<div class="section-header font-mono">
				<span class="sec-number">04 /</span>
				<h2 class="sec-title">toolbelt ecosystem</h2>
			</div>

			<div class="tabs-brutalist">
				<!-- Tab List -->
				<div class="tabs-list font-mono" role="tablist">
					<button class="tabs-btn active" data-tab="mutation" role="tab">mutation</button>
					<button class="tabs-btn" data-tab="search" role="tab">exploration</button>
					<button class="tabs-btn" data-tab="lsp" role="tab">intellisense</button>
					<button class="tabs-btn" data-tab="experts" role="tab">subagents-experts</button>
				</div>

				<!-- Panels -->
				<div class="panels-list font-mono">
					<!-- Mutation -->
					<div class="panel-item active" id="panel-mutation" role="tabpanel">
						<table class="brutalist-table">
							<thead>
								<tr>
									<th>Tool</th>
									<th>Description</th>
								</tr>
							</thead>
							<tbody>
								<tr>
									<td class="tab-accent-text">read</td>
									<td>Inspects target line slices or full files.</td>
								</tr>
								<tr>
									<td class="tab-accent-text">write</td>
									<td>Creates files in workspace.</td>
								</tr>
								<tr>
									<td class="tab-accent-text">edit</td>
									<td>Applies patches via `@oh-my-pi/hashline`.</td>
								</tr>
								<tr>
									<td class="tab-accent-text">undo / history</td>
									<td>Reverts file changes via ChangeTracker mutation logs.</td>
								</tr>
							</tbody>
						</table>
					</div>

					<!-- Search -->
					<div class="panel-item" id="panel-search" role="tabpanel">
						<table class="brutalist-table">
							<thead>
								<tr>
									<th>Tool</th>
									<th>Description</th>
								</tr>
							</thead>
							<tbody>
								<tr>
									<td class="tab-accent-text">ripgrep</td>
									<td>Fast regex codebase search wrapping the `rg` binary.</td>
								</tr>
								<tr>
									<td class="tab-accent-text">codebase_semantic_search</td>
									<td>Vector-indexed semantic code search using embeddings.</td>
								</tr>
								<tr>
									<td class="tab-accent-text">glob / grep</td>
									<td>Finds paths or text patterns matching glob filters.</td>
								</tr>
							</tbody>
						</table>
					</div>

					<!-- LSP -->
					<div class="panel-item" id="panel-lsp" role="tabpanel">
						<table class="brutalist-table">
							<thead>
								<tr>
									<th>Tool</th>
									<th>Description</th>
								</tr>
							</thead>
							<tbody>
								<tr>
									<td class="tab-accent-text">lsp_hover</td>
									<td>Inspects type declarations and comments.</td>
								</tr>
								<tr>
									<td class="tab-accent-text">lsp_definition</td>
									<td>Goes directly to a symbol's declaration path.</td>
								</tr>
								<tr>
									<td class="tab-accent-text">lsp_references</td>
									<td>Finds where a symbol is referenced across files.</td>
								</tr>
								<tr>
									<td class="tab-accent-text">lsp_diagnostics</td>
									<td>Checks for typescript-language-server and lint warnings.</td>
								</tr>
							</tbody>
						</table>
					</div>

					<!-- Experts -->
					<div class="panel-item" id="panel-experts" role="tabpanel">
						<table class="brutalist-table">
							<thead>
								<tr>
									<th>Tool</th>
									<th>Description</th>
								</tr>
							</thead>
							<tbody>
								<tr>
									<td class="tab-accent-text">deploy_parallel_subs</td>
									<td>Spawns up to 3 parallel Flue processes for deep research.</td>
								</tr>
								<tr>
									<td class="tab-accent-text">query_expert</td>
									<td>Spawns a specialized read-only advisor (ui, logic, refactor).</td>
								</tr>
								<tr>
									<td class="tab-accent-text">oracle</td>
									<td>Fetches conceptual checks from lightweight secondary models.</td>
								</tr>
							</tbody>
						</table>
					</div>
				</div>
			</div>
		</section>

		<!-- Row 8: Setup Guide (Full Width) -->
		<section id="setup" class="grid-cell col-12 setup-cell font-mono">
			<div class="section-header">
				<span class="sec-number">05 /</span>
				<h2 class="sec-title">quickstart setup</h2>
			</div>

			<div class="setup-grid">
				<div class="setup-col">
					<div class="step-badge">STEP_01</div>
					<h3 class="step-title font-serif">install binary</h3>
					<pre class="setup-code">curl -fsSL https://lavalamp.marban.lol/install.sh | bash</pre>
				</div>
				<div class="setup-col">
					<div class="step-badge">STEP_02</div>
					<h3 class="step-title font-serif">wrangler login</h3>
					<pre class="setup-code">lavalamp login</pre>
				</div>
				<div class="setup-col">
					<div class="step-badge">STEP_03</div>
					<h3 class="step-title font-serif">launch harness</h3>
					<pre class="setup-code">lavalamp</pre>
				</div>
			</div>

			<!-- Terminal Configuration Box -->
			<div class="terminal-config-box">
				<div class="config-line"><span class="comment-text"># map default model path:</span></div>
				<div class="config-line">$ lavalamp config set model @cf/zai-org/glm-4.7-flash</div>
				<div class="config-line"><span class="comment-text"># check configuration details:</span></div>
				<div class="config-line">$ lavalamp config show</div>
				<div class="config-line green-text">⚙ Active Profile Configured:</div>
				<div class="config-line">  Provider: cloudflare-workers-ai</div>
				<div class="config-line">  Model: @cf/zai-org/glm-4.7-flash</div>
				<div class="config-line">  AI Gateway: bypass (direct client)</div>
			</div>
		</section>

		<!-- Row 9: Footer (Full Width) -->
		<footer class="grid-cell col-12 footer-cell font-mono">
			<div class="footer-brand">
				<pre class="footer-ascii-logo">
       _____
      /     \
      |_____|
      /  _  \
     /  ( )  \
    /    `    \
   /     _     \
  /     ( )     \
  \      )\     /
   \    (  )   /
    \  ,-(   /
     \/-----\/
     |       |
     /       \
    /________\--._
               .-._)
              (__
                 -`|E
				</pre>
				<span class="footer-sub font-serif">local cloudflare AI coding harness.</span>
			</div>
			<div class="footer-links-grid">
				<div class="footer-links-col">
					<span class="col-header">RESOURCES</span>
					<a href="https://github.com/rahuletto/lavalamp">github-repo</a>
					<a href="https://github.com/rahuletto/lavalamp/blob/main/LICENSE">mit-license</a>
				</div>
				<div class="footer-links-col">
					<span class="col-header">SYSTEMS</span>
					<a href="https://astro.build">astro-static</a>
					<a href="https://flue.dev">flue-runtime</a>
					<a href="https://developers.cloudflare.com/workers-ai/">workers-ai</a>
				</div>
			</div>
		</footer>

	</div>
</Layout>

<style is:global>
	/* =========================================
	   BRUTALIST GRID DESIGN SYSTEM
	   ========================================= */
	
	/* Layout Master Grid */
	.master-grid {
		display: grid;
		grid-template-columns: repeat(12, 1fr);
		max-width: 1100px;
		margin: 0 auto;
		border-left: 1px solid var(--color-border);
		border-right: 1px solid var(--color-border);
		box-sizing: border-box;
	}

	/* Responsive Grid Cells */
	.grid-cell {
		border-bottom: 1px solid var(--color-border);
		box-sizing: border-box;
	}

	.col-12 {
		grid-column: span 12;
	}

	.col-6 {
		grid-column: span 12;
	}

	@media (min-width: 768px) {
		.col-6 {
			grid-column: span 6;
		}
	}

	.cell-padding {
		padding: 4rem 2rem;
	}

	/* Nav Header */
	.nav-header {
		display: flex;
		justify-content: space-between;
		align-items: center;
		padding: 1.5rem 2rem;
	}

	.logo {
		display: flex;
		align-items: center;
		text-decoration: none;
		gap: 0.5rem;
	}

	.logo-ascii {
		margin: 0;
		font-family: var(--font-mono);
		font-size: 0.2rem;
		line-height: 0.95;
		color: var(--color-accent);
		white-space: pre;
		transition: color 0.1s ease;
	}

	.logo:hover .logo-ascii {
		color: var(--color-white);
	}

	.nav-links {
		display: flex;
		gap: 2rem;
	}

	.nav-links a {
		color: var(--color-gray);
		text-decoration: none;
		font-size: 0.85rem;
		font-weight: 500;
		text-transform: lowercase;
		transition: color 0.1s ease;
	}

	.nav-links a:hover {
		color: var(--color-white);
	}

	.nav-links a.cta-link {
		color: var(--color-white);
		border-bottom: 2px solid var(--color-accent);
	}

	.github-link {
		text-decoration: none;
		color: var(--color-gray);
		font-size: 0.85rem;
		border-bottom: 1px solid transparent;
		transition: all 0.1s ease;
	}

	.github-link:hover {
		color: var(--color-white);
		border-bottom-color: var(--color-white);
	}

	/* Hero Section */
	.hero-left-cell {
		display: flex;
		align-items: center;
	}

	@media (min-width: 768px) {
		.hero-left-cell {
			border-right: 1px solid var(--color-border);
		}
	}

	.hero-intro {
		display: flex;
		flex-direction: column;
		gap: 1.5rem;
	}

	.badge {
		font-size: 0.72rem;
		color: var(--color-accent);
		letter-spacing: 0.08em;
	}

	.hero-title {
		font-family: var(--font-serif);
		font-size: 3.2rem;
		font-weight: 300;
		line-height: 1.15;
		letter-spacing: -0.03em;
		margin: 0;
		text-transform: none;
		color: var(--color-white);
	}

	.accent-italic {
		font-style: italic;
		color: var(--color-accent);
	}

	.hero-details {
		display: flex;
		flex-direction: column;
		justify-content: center;
		height: 100%;
		gap: 2rem;
		padding: 4rem 2rem;
	}

	.hero-desc {
		font-size: 1.1rem;
		font-weight: 300;
		color: var(--color-gray);
		line-height: 1.6;
		margin: 0;
		max-width: 480px;
	}

	/* Brutalist Command Box / Switcher */
	.install-box {
		display: flex;
		flex-direction: column;
		border: 1px solid var(--color-border);
		background-color: var(--color-input-bg);
		max-width: 650px;
		width: 100%;
	}

	.install-tabs {
		display: flex;
		background-color: #0b0c12;
		border-bottom: 1px solid var(--color-border);
	}

	.install-tab {
		flex-grow: 1;
		background: none;
		border: none;
		color: var(--color-dim);
		font-family: var(--font-mono);
		font-size: 0.75rem;
		padding: 0.5rem 0;
		cursor: pointer;
		transition: all 0.1s ease;
		text-align: center;
	}

	.install-tab:hover {
		color: var(--color-white);
	}

	.install-tab.active {
		color: var(--color-accent);
		background-color: var(--color-input-bg);
		font-weight: bold;
	}

	.install-command-row {
		display: flex;
		align-items: center;
		padding: 1rem 1.25rem;
		gap: 1.25rem;
	}

	.shell-prompt {
		flex-grow: 1;
		font-size: 0.95rem;
		color: var(--color-white);
		white-space: nowrap;
		overflow-x: auto;
		display: block;
		padding: 0.3rem 0;
		scrollbar-width: none;
		-ms-overflow-style: none;
	}

	.shell-prompt::-webkit-scrollbar {
		display: none;
	}

	.install-copy-btn {
		background-color: transparent;
		border: 1px solid var(--color-border);
		color: var(--color-white);
		font-family: var(--font-mono);
		font-size: 0.85rem;
		padding: 0.4rem 1rem;
		cursor: pointer;
		transition: all 0.1s ease;
	}

	.install-copy-btn:hover {
		background-color: var(--color-white);
		color: var(--color-dark-bg);
		border-color: var(--color-white);
	}

	/* Sandbox TUI Window Section */
	.sandbox-cell {
		padding: 4rem 2rem;
	}

	.section-header {
		display: flex;
		align-items: baseline;
		gap: 0.5rem;
		margin-bottom: 2.5rem;
	}

	.sec-number {
		font-size: 0.85rem;
		color: var(--color-accent);
		font-weight: 700;
	}

	.sec-title {
		font-family: var(--font-serif);
		font-size: 1.8rem;
		font-weight: 400;
		letter-spacing: -0.02em;
		margin: 0;
		text-transform: lowercase;
	}

	.sandbox-container {
		display: grid;
		grid-template-columns: 1fr;
		align-items: start;
	}

	/* 1:1 TUI Sandbox Replica (with corner brackets matching pi.dev) */
	.tui-figure-frame {
		position: relative;
		margin: 0;
		padding: 1.5rem;
		background-color: #0b0c10;
