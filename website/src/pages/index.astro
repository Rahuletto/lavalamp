<!-- Script for Interactive Terminal Demo & Copy Installer -->
<script>
	// Copy installer script
	const copyBtn = document.getElementById('copyInstallBtn');
	
	if (copyBtn) {
		copyBtn.addEventListener('click', async () => {
			// Copy active command
			const activeCommand = document.querySelector('.shell-prompt:not([hidden])');
			const installCmdText = activeCommand?.textContent || '';
			try {
				await navigator.clipboard.writeText(installCmdText);
				copyBtn.textContent = 'Copied';
				setTimeout(() => {
					copyBtn.textContent = 'Copy';
				}, 2000);
			} catch (err) {
				console.error('Failed to copy text', err);
			}
		});
	}

	// Install tabs switching
	const installTabs = document.querySelectorAll('[data-install-switcher] .install-tab');
	const installPrompts = document.querySelectorAll('[data-install-switcher] .shell-prompt');

	installTabs.forEach(tab => {
		tab.addEventListener('click', () => {
			const targetTab = tab.getAttribute('data-tab');

			// Update tabs
			installTabs.forEach(t => t.classList.remove('active'));
			tab.classList.add('active');

			// Update prompts
			installPrompts.forEach(p => {
				if (p.getAttribute('id') === `install-${targetTab}`) {
					p.removeAttribute('hidden');
				} else {
					p.setAttribute('hidden', 'true');
				}
			});
		});
	});

	// Toolbelt tabs interaction
	const tabs = document.querySelectorAll('.tabs-btn');
	const panels = document.querySelectorAll('.panel-item');

	tabs.forEach(tab => {
		tab.addEventListener('click', () => {
			const targetPanelId = 'panel-' + tab.getAttribute('data-tab');
			
			// Deactivate all
			tabs.forEach(t => t.classList.remove('active'));
			panels.forEach(p => p.classList.remove('active'));

			// Activate current
			tab.classList.add('active');
			const targetPanel = document.getElementById(targetPanelId);
			if (targetPanel) targetPanel.classList.add('active');
		});
	});

