			} else {
				tuiChatStream?.appendChild(div);
			}
			
			const diffBody = div.querySelector('#tui-diff-body');
			if (diffBody && step.changes) {
				step.changes.forEach(c => {
					const span = document.createElement('span');
					if (c.type === 'add') span.className = 'diff-add';
					else if (c.type === 'del') span.className = 'diff-del';
					else span.className = 'diff-ctx';
					span.textContent = c.text;
					diffBody.appendChild(span);
				});
			}
			
			if (toolBody) toolBody.removeAttribute('id');
			const activeTool = document.getElementById('tui-active-tool');
			if (activeTool) activeTool.removeAttribute('id');

			tuiMessagesPanel?.scrollTo(0, tuiMessagesPanel.scrollHeight);
			currentStep++;
			simTimeout = setTimeout(runPlayback, 1000);
		} else if (step.type === 'permission_gate') {
			if (tuiTaskStatusBar) tuiTaskStatusBar.style.display = 'flex';
			if (tuiTaskStatusText) tuiTaskStatusText.textContent = 'awaiting permission';
			stopSpinner();

			const div = document.createElement('div');
			div.className = 'sim-perm-request';
			div.id = 'tui-active-perm';
			div.innerHTML = `
				<div class="sim-perm-border">┌ Permission Required ─────────────────────────────────────────────────────────┐</div>
				<div class="sim-perm-row">  Tool: edit</div>
				<div class="sim-perm-row">  File: ${step.path}</div>
				<div class="sim-perm-btn-row">
					<button class="sim-perm-btn" id="tuiAllowBtn">[y] Allow</button>
					<button class="sim-perm-btn">[n] Deny</button>
					<button class="sim-perm-btn">[a] Always Allow</button>
				</div>
				<div class="sim-perm-row" style="color:var(--color-dim); margin-top:0.25rem;">  Escape to deny · Auto-deny in 30s</div>
				<div class="sim-perm-border">└────────────────────────────────────────────────────────────────────────────────┘</div>
			`;
			tuiChatStream?.appendChild(div);
			tuiMessagesPanel?.scrollTo(0, tuiMessagesPanel.scrollHeight);

			const allowBtn = document.getElementById('tuiAllowBtn');
			if (allowBtn) {
				allowBtn.addEventListener('click', () => {
					allowBtn.textContent = 'ALLOWED ✔';
					setTimeout(() => {
						const activePerm = document.getElementById('tui-active-perm');
						if (activePerm) activePerm.remove();
						currentStep++;
						runPlayback();
					}, 400);
				});
				
				// Auto click for demo
				simTimeout = setTimeout(() => {
					allowBtn.click();
				}, 1500);
			}
		} else if (step.type === 'task_complete') {
			if (step.id === 'bst' && taskBst) {
				taskBst.className = 'tui-panel-row done';
				taskBst.textContent = '  [x] #1 create LRU cache in src/cache.ts';
				if (taskTest) {
					taskTest.className = 'tui-panel-row active';
					taskTest.textContent = '  [>] #2 integrate with db in src/db.ts';
				}
			} else if (step.id === 'test' && taskTest) {
				taskTest.className = 'tui-panel-row done';
				taskTest.textContent = '  [x] #2 integrate with db in src/db.ts';
			}
			currentStep++;
			runPlayback();

		}
	}

	function startSimulation() {
		if (simTimeout) clearTimeout(simTimeout);
		currentStep = 0;
		resetTuiWidgets();
		runPlayback();
	}

	// Trigger simulation automatically on page load and loop infinitely
	setTimeout(startSimulation, 1000);
</script>
