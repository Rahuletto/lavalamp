							tuiInputField.textContent = '';
							
							const tuiCompletionBox = document.getElementById('tuiCompletionBox');
							if (tuiCompletionBox) tuiCompletionBox.style.display = 'none';
							
							// Execute TUI reset and start the next simulation loop
							simTimeout = setTimeout(startSimulation, 800);
						}, 400);
					});
				} else {
					startSimulation();
				}
			}, 3000);
			return;
		}

		const step = demoScript[currentStep];

		if (step.type === 'wait') {
			simTimeout = setTimeout(() => {
				currentStep++;
				runPlayback();
			}, step.duration);
		} else if (step.type === 'status') {
			if (tuiTaskStatusBar) tuiTaskStatusBar.style.display = 'flex';
			if (tuiTaskStatusText) tuiTaskStatusText.textContent = step.text || 'running';
			startSpinner();
			startBottomSpinner();
			currentStep++;
